# Application
APP_NAME=Smart Parking System
DEBUG=false
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://parking:parking_secret@db:5432/smart_parking
DATABASE_URL_SYNC=postgresql+psycopg2://parking:parking_secret@db:5432/smart_parking

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Business rules
RESERVATION_GRACE_PERIOD_MINUTES=15
SENSOR_WEBHOOK_API_KEY=dev-sensor-webhook-key

# Celery beat (cron-style, UTC)
DAILY_REPORT_HOUR=0
DAILY_REPORT_MINUTE=0

# Dev bootstrap (auto-seed demo users/spots on API startup)
SEED_ON_STARTUP=true
